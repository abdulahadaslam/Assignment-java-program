import java.util.Scanner;

public class PartC {

    
    static String toBinaryString(int num) {
        if (num == 0) {
            return "0";
        }

        String binary = "";

   
        while (num > 0) {
            binary = (num % 2) + binary;
            num = num / 2;
        }

        return binary;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int num = sc.nextInt();


        String output = toBinaryString(num);
        System.out.println("Binary of " + num + " is: " + output);

        sc.close(); }
}
